{
	"name": "bazaar-dl",
	"version": "2.0.0",
	"description": "Generate direct APK download links from cafebazaar.ir",
	"type": "module",
	"main": "./dist/cli.js",
	"types": "./dist/cli.d.ts",
	"exports": {
		".": {
			"types": "./dist/cli.d.ts",
			"import": "./dist/cli.js"
		},
		"./api": {
			"types": "./dist/api.d.ts",
			"import": "./dist/api.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js"
		}
	},
	"bin": {
		"bazaar-dl": "bin/bazaar-dl.js",
		"bazaar_dl": "bin/bazaar-dl.js"
	},
	"files": [
		"bin",
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build",
		"start": "node dist/bin.js",
		"test": "tsx --test test/**/*.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ssshojaei/bazaar-dl.git"
	},
	"keywords": [
		"cafebazaar",
		"apk",
		"bazaar",
		"cafebazaar.ir",
		"cli"
	],
	"author": "SSShojaei",
	"license": "GPL-3.0-or-later",
	"bugs": {
		"url": "https://github.com/ssshojaei/bazaar-dl/issues"
	},
	"homepage": "https://github.com/ssshojaei/bazaar-dl#readme",
	"dependencies": {
		"cheerio": "^1.1.0",
		"commander": "^14.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"tsx": "^4.20.0",
		"typescript": "^5.9.0"
	}
}
